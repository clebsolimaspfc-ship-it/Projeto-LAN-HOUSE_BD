CREATE TABLE Cliente (
    idCliente INT AUTO_INCREMENT,
    nome VARCHAR(100) NOT NULL,
    cpf CHAR(14) NOT NULL,
    email VARCHAR(100) NOT NULL,
    telefone VARCHAR(20),
    data_cadastro DATETIME NOT NULL,
    CONSTRAINT PK_Cliente PRIMARY KEY (idCliente),
    CONSTRAINT UN_Cliente_email UNIQUE (email),
    CONSTRAINT UN_Cliente_cpf UNIQUE (cpf)
);

CREATE TABLE Computador (
    idComputador INT AUTO_INCREMENT,
    nome VARCHAR(50) NOT NULL,
    especificacao TEXT,
    status VARCHAR(10) NOT NULL,
    preco_hora DECIMAL(10,2) NOT NULL,
    CONSTRAINT PK_Computador PRIMARY KEY (idComputador)
);

CREATE TABLE Administrador (
    idAdministrador INT AUTO_INCREMENT,
    nome VARCHAR(100) NOT NULL,
    email VARCHAR(100) NOT NULL,
    senha_hash VARCHAR(255) NOT NULL,
    nivel_acesso VARCHAR(20) NOT NULL,
    ultimo_login DATETIME,
    CONSTRAINT PK_Administrador PRIMARY KEY (idAdministrador),
    CONSTRAINT UN_Administrador_email UNIQUE (email)
);

CREATE TABLE Torneio (
    idtorneio INT AUTO_INCREMENT,
    nome VARCHAR(100) NOT NULL,
    jogo VARCHAR(100) NOT NULL,
    data_torneio DATETIME NOT NULL,
    premio DECIMAL(10,2),
    descricao TEXT,
    CONSTRAINT PK_Torneio PRIMARY KEY (idtorneio)
);

CREATE TABLE forma_pagamento (
    idforma_pagamento INT AUTO_INCREMENT,
    nome VARCHAR(45) NOT NULL,
    descricao TEXT,
    CONSTRAINT PK_forma_pagamento PRIMARY KEY (idforma_pagamento)
);

CREATE TABLE Produto (
    idProduto INT AUTO_INCREMENT,
    nome VARCHAR(100) NOT NULL,
    preco DECIMAL(10,2) NOT NULL,
    estoque INT NOT NULL,
    categoria VARCHAR(100),
    CONSTRAINT PK_Produto PRIMARY KEY (idProduto)
);

CREATE TABLE Inscricao (
    idInscricao INT AUTO_INCREMENT,
    data_inscricao DATETIME NOT NULL,
    Id_torneio INT NOT NULL,
    id_cliente INT NOT NULL,
    CONSTRAINT PK_Inscricao PRIMARY KEY (idInscricao),
    CONSTRAINT FK_Inscricao_Torneio FOREIGN KEY (Id_torneio) REFERENCES Torneio (idtorneio),
    CONSTRAINT FK_Inscricao_Cliente FOREIGN KEY (id_cliente) REFERENCES Cliente (idCliente)
);

CREATE TABLE Audit_log (
    idAudit_log INT AUTO_INCREMENT,
    tabela_afetada VARCHAR(100) NOT NULL,
    acao VARCHAR(20) NOT NULL,
    descricao TEXT,
    ip_origem VARCHAR(45),
    data_evento DATETIME NOT NULL,
    id_cliente INT,
    Id_administrador INT,
    CONSTRAINT PK_Audit_log PRIMARY KEY (idAudit_log),
    CONSTRAINT FK_Audit_log_Cliente FOREIGN KEY (id_cliente) REFERENCES Cliente (idCliente),
    CONSTRAINT FK_Audit_log_Administrador FOREIGN KEY (Id_administrador) REFERENCES Administrador (idAdministrador)
);

CREATE TABLE Sessao (
    idSessoe INT AUTO_INCREMENT,
    inicio DATETIME NOT NULL,
    fim DATETIME,
    valor_total DECIMAL(10,2),
    status VARCHAR(10) NOT NULL,
    id_cliente INT NOT NULL,
    id_computador INT NOT NULL,
    CONSTRAINT PK_Sessao PRIMARY KEY (idSessoe),
    CONSTRAINT FK_Sessao_Cliente FOREIGN KEY (id_cliente) REFERENCES Cliente (idCliente),
    CONSTRAINT FK_Sessao_Computador FOREIGN KEY (id_computador) REFERENCES Computador (idComputador)
);

CREATE TABLE Consumo (
    idconsumo INT AUTO_INCREMENT,
    quantidade INT NOT NULL,
    subtotal DECIMAL(10,2) NOT NULL,
    data_consumo DATETIME NOT NULL,
    id_sessao INT NOT NULL,
    id_forma_pagamento INT NOT NULL,
    id_produto INT NOT NULL,
    CONSTRAINT PK_Consumo PRIMARY KEY (idconsumo),
    CONSTRAINT FK_Consumo_Sessao FOREIGN KEY (id_sessao) REFERENCES Sessao (idSessoe),
    CONSTRAINT FK_Consumo_FormaPagamento FOREIGN KEY (id_forma_pagamento) REFERENCES forma_pagamento (idforma_pagamento),
    CONSTRAINT FK_Consumo_Produto FOREIGN KEY (id_produto) REFERENCES Produto (idProduto)
);
